NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-only key (Supabase project settings -> API -> service_role). Never
# expose this with a NEXT_PUBLIC_ prefix. Used by /api/send-confirmation to
# look up a mentor's email without the client ever querying it directly.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Server-only key (Resend dashboard -> API Keys). Required by
# /api/send-confirmation to send session-confirmation emails; the route
# returns a 500 "Email not configured" if this is missing.
RESEND_API_KEY=your_resend_api_key
# Optional. The "from" address used when sending confirmation emails via
# Resend. Must be a verified sender/domain in your Resend account, or
# sending will fail. Falls back to "onboarding@resend.dev" (Resend's
# shared sandbox sender) if unset.
RESEND_FROM_EMAIL=your_verified_sender_email
